# Copy this file to ".env" if you need to override defaults.

# Streamlit web app port exposed on the host (only for docker)
LOGRE_PORT=8501

# RDF4J SPARQL endpoint (Server + Workbench) port exposed on the host  (only for docker)
RDF4J_SERVER_PORT=8080

# Repository name created inside RDF4J
# Available at:
# http://localhost:${RDF4J_SERVER_PORT}/rdf4j-server/repositories/${RDF4J_REPOSITORY}
RDF4J_REPOSITORY=logre

# Optional: override the RDF4J server URL the app targets
# (use this when pointing Logre to an external SPARQL server)
# RDF4J_SERVER_URL=http://rdf4j:8080/rdf4j-server

# Optional: customise the URL polled while waiting for RDF4J to be ready
# RDF4J_HEALTHCHECK_URL=http://rdf4j:8080/rdf4j-server/

# Optional: skip automatic repository creation
# (set to 0 when the target server is managed elsewhere)
# RDF4J_BOOTSTRAP_REPOSITORY=1

# Optional: display queries executed by graphly in the logs
# GRAPHLY_MODE=normal # GRAPHLY_MODE=debug

# Optional: endpoint credentials (used when config has ${LOGRE_SPARQL_USERNAME} / ${LOGRE_SPARQL_PASSWORD})
# LOGRE_SPARQL_USERNAME=
# LOGRE_SPARQL_PASSWORD=

# Optional: timeout in seconds for SPARQL HTTP requests
# LOGRE_SPARQL_TIMEOUT=12

# Optional: initial line chunk size for N-Quads uploads
# Logre auto-reduces this value when endpoint returns HTTP 413
# LOGRE_NQUADS_CHUNK_LINES=10000

# Optional: set a python version to use for Logre to start on
# PYTHON=python3.10

# Optional: override configuration location
# LOGRE_CONFIG_HOME=/path/to/config/dir
# LOGRE_CONFIG_PATH=/path/to/config/file.yaml
